# --- Продакшен на EC2 + Aurora ---
APP_PORT=8000
HTTP_PORT=80
VITE_API_URL=/api

WEBAPP_URL=https://vibemovie.ru
CORS_ALLOW_ORIGINS=https://vibemovie.ru

DATABASE_URL=postgresql+asyncpg://postgres:ПАРОЛЬ@arseniy-vibemovie.cluster-xxxxx.us-east-1.rds.amazonaws.com:5432/vibemovie
BOT_DATABASE_URL=postgresql://postgres:ПАРОЛЬ@arseniy-vibemovie.cluster-xxxxx.us-east-1.rds.amazonaws.com:5432/vibemovie

BOT_TOKEN=your_telegram_bot_token
RANDOM_WORDS=word1,word2,word3

